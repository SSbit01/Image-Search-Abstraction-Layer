extends layout.pug

block title
  = q

block content
  script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.min.js" integrity="sha384-QJHtvGhmr9XOIpI6YVutG+2QOK9T+ZnN4kzFN1RtK3zEFEIsxhlmWl5/YESvpZ13" crossorigin="anonymous")
  nav.navbar.navbar-expand-lg.navbar-dark.bg-dark.sticky-top.px-4
    a.navbar-brand(href="/") ISAL
    button.navbar-toggler(type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation")
      span.navbar-toggler-icon
    #navbarContent.collapse.navbar-collapse
      ul.navbar-nav.me-3
        li.nav-item: a.nav-link(href="/api") API
        if show_recent
          li.nav-item: a.nav-link(href="/recent") Recent Searches
      .ms-auto
        include includes/form.pug
  .text-center
    if Array.isArray(images) && images.length
      each i in images
        a(href=i.pageURL target="_blank")
          img.m-1(src=i.previewURL alt=i.tags title=i.tags)
    else
      h1.mx-2 Ooops! There are no results :(